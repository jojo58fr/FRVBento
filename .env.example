NEXT_PUBLIC_ENABLE_LANDING=false
NEXT_PUBLIC_BASE_PATH=

# FRVtubers auth (client)
NEXT_PUBLIC_FRVTUBERS_AUTH_ORIGIN=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_FRVSTREAM_CALLBACK_URL=

# FRVtubers auth (server)
FRVTUBERS_AUTH_ORIGIN=
FRVTUBERS_API_BASE_URL=
FRVTUBERS_API_VERIFY_PATH=/auth/verify

# Public base URL for published links
PUBLIC_BASE_URL=

# Custom domains
CUSTOM_DOMAIN_CNAME_TARGET=cname.frvtubers.com

# Database (Prisma)
DATABASE_URL="file:./prisma/data/bento.sqlite"

# Optional: Supabase analytics (scripts/supabase-analytics-init.mjs)
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
OPENBENTO_ANALYTICS_ADMIN_TOKEN=
SUPABASE_URL=

# Optional: AI (vite.config.ts)
GEMINI_API_KEY=
