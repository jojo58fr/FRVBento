generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bento {
  id        String         @id
  data      Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  ownerId   String?
  owner     User?          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  published PublishedBento?
  customDomains CustomDomain[]
}

model User {
  id          String  @id
  discordId   String? @unique
  username    String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bentos      Bento[]
  customDomains CustomDomain[]
}

model PublishedBento {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  bentoId   String   @unique
  bento     Bento    @relation(fields: [bentoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomDomain {
  id                 Int      @id @default(autoincrement())
  domain             String   @unique
  status             String   @default("pending")
  verificationToken  String
  bentoId            String
  ownerId            String?
  verifiedAt         DateTime?
  lastCheckedAt      DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  bento              Bento    @relation(fields: [bentoId], references: [id], onDelete: Cascade)
  owner              User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}
